{
  "name": "n8n-nodes-morpho",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Morpho DeFi lending protocol providing 20 resources and 200+ operations for decentralized lending, borrowing, MetaMorpho vaults, and DeFi analytics. Includes support for Morpho Blue, liquidations, governance, and bundled transactions.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-morpho.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-morpho#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-morpho/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "morpho",
    "morpho-blue",
    "metamorpho",
    "defi",
    "lending",
    "borrowing",
    "ethereum",
    "base",
    "blockchain",
    "web3",
    "decentralized-finance",
    "yield",
    "vaults",
    "liquidation",
    "collateral",
    "oracle",
    "governance"
  ],
  "main": "dist/nodes/Morpho/Morpho.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/MorphoNetwork.credentials.js",
      "dist/credentials/MorphoApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Morpho/Morpho.node.js",
      "dist/nodes/Morpho/MorphoTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "axios": "^1.6.2",
    "ethers": "^6.9.0",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}